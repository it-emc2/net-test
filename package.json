{
  "name": "net-test",
  "version": "1.0.0",
  "description": "EMC2 Konfigurator API + Frontend server",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext js,mjs,json src/app.js",
    "start": "node src/app.js",
    "seed:products": "node scripts/seedProducts.js",
    "seed:flexofit": "node scripts/seedFlexofit.js",
    "seed:badewannen": "node scripts/seedBadewannen.js",
    "seed:badolux": "node scripts/seedbadolux.js",
    "health": "node -e \"fetch('http://localhost:'+(process.env.PORT||3000)+'/api/health').then(r=>r.text()).then(console.log).catch(console.error)\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/e2e",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,mjs,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,mjs,json}\"",
    "scenarios": "node ./scripts/run-scenarios.mjs",
    "validate": "npm run lint && npm run test:unit",
    "test:address": "node scripts/test-routing.mjs"
  },
  "keywords": [
    "express",
    "mongoose",
    "mongo",
    "konfigurator",
    "pricing"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@adobe/pdfservices-node-sdk": "^4.1.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "axios": "^1.13.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.18",
    "docx-templates": "^4.14.1",
    "docxtemplater": "^3.66.2",
    "docxtemplater-image-module-free": "^1.1.1",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "mammoth": "^1.11.0",
    "mongoose": "^8.18.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.449",
    "pdfkit": "^0.17.2",
    "pdflatex": "^0.0.1",
    "pizzip": "^3.2.0",
    "puppeteer": "^24.22.3",
    "soffice": "^1.1.0",
    "string-width": "^8.1.0",
    "strip-ansi": "^7.1.2",
    "typescript": "^5.9.3",
    "wrap-ansi": "^9.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@flydotio/dockerfile": "^0.7.10",
    "@playwright/test": "^1.61.0",
    "@types/jest": "^29.5.14",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.9.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jsdom": "^25.0.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.17"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/public/**",
      "!src/templates/**",
      "!src/app.js",
      "!src/server.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/coverage/"
    ],
    "verbose": true,
    "testTimeout": 10000,
    "globals": {
      "jest": true
    }
  }
}
